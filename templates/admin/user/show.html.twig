{% extends 'base.html.twig' %}

{% block title %}Fiche utilisateur
{% endblock %}

{% block body %}
	<h1>Fiche utilisateur</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ user.id }}</td>
			</tr>
			<tr>
				<th>E-mail</th>
				<td>{{ user.email }}</td>
			</tr>
			<tr>
				<th>Rôles</th>
				<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
			</tr>
			<tr>
				<th>Mot de passe</th>
				<td>{{ user.password }}</td>
			</tr>
			<tr>
				<th>Nom</th>
				<td>{{ user.lastname }}</td>
			</tr>
			<tr>
				<th>Prénom</th>
				<td>{{ user.firstname }}</td>
			</tr>
			<tr>
				<th>Addresse</th>
				<td>{{ user.address }}</td>
			</tr>
			<tr>
				<th>Ville</th>
				<td>{{ user.city }}</td>
			</tr>
			<tr>
				<th>Code postal</th>
				<td>{{ user.postcode }}</td>
			</tr>
			<tr>
				<th>Téléphone</th>
				<td>{{ user.phone }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('user_index') }}">Retour à la liste</a>

	<a href="{{ path('user_edit', {'id': user.id}) }}">Modifier la fiche</a>

	{{ include('user/_delete_form.html.twig') }}
{% endblock %}
