{% extends 'base.html.twig' %}

{% block title %}User index
{% endblock %}

{% block body %}
	<h1>User index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>E-mail</th>
				<th>Roles</th>
				<th>Nom</th>
				<th>Prénom</th>
				<th>Addresse</th>
				<th>Ville</th>
				<th>Code postal</th>
				<th>Téléphone</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for user in users %}
				<tr>
					<td>{{ user.email }}</td>
					<td>{{ user.roles ? user.roles|json_encode : '' }}</td>
					<td>{{ user.lastname }}</td>
					<td>{{ user.firstname }}</td>
					<td>{{ user.address }}</td>
					<td>{{ user.city }}</td>
					<td>{{ user.postcode }}</td>
					<td>{{ user.phone }}</td>
					<td>
						<a href="{{ path('user_show', {'id': user.id}) }}">Voir la fiche</a>
						<a href="{{ path('user_edit', {'id': user.id}) }}">Modifier</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="11">Aucun enregistrement.</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('user_new') }}">Créer un utilisateur</a>
{% endblock %}
