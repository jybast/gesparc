{% extends 'base.html.twig' %}

{% block title %}Se connecter
{% endblock %}
{% block nav %}
	{% include "includes/_head.html.twig" %}

{% endblock %}
{% block body %}
	<div class="col-sm-12 col-md col-lg">
		<div class="container">
			<div class="page-content--bge5">
				<div class="login-wrap">
					<div class="login-content">

						<div class="login-logo">
							<img width="120px" height="45px" src="{{asset('assets/img/logo_horizontal.png')}}" alt="Gesparc">
						</div>


						<div class="login-form">
							<form method="post">
								{% if error %}
									<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
								{% endif %}

								{% if app.user %}
									<div class="mb-3">
										Vous êtes déjà connecté en tant que
										{{ app.user.username }},
										<a href="{{ path('app_logout') }}">Quitter</a>
									</div>
								{% endif %}

								<h1 class="h3 mb-3 text-center font-weight-normal">Se connecter</h1>

								<div class="form-group">
									<label>Adresse E-mail</label>
									<input class="au-input au-input--full" id="inputEmail" type="email" name="email" value="{{ last_username }}" autocomplete="email" required autofocus placeholder="Renseigner votre E-mail">
								</div>

								<div class="form-group">
									<label>Mot de passe</label>
									<input class="au-input au-input--full" id="inputPassword" type="password" name="password" autocomplete="current-password" required placeholder="Entrer votre mot de passe">
								</div>
								<div class="text-center m-t-5 m-b-20">
									<label>
										<a href="{{path('app_forgot_password_request')}}">Mot de passe oublié ?</a>
									</label>
								</div>
								<div class="login-checkbox">
									<label>
										<input type="checkbox" name="remember">Remember Me
									</label>
								</div>
								<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
								<button class="au-btn au-btn--block au-btn--green m-b-20" type="submit">Se connecter</button>
							</form>
							<div class="register-link">
								<p>
									Pas encore inscrit ?
									<a href="{{path('app_register')}}">S'inscrire ICI</a>
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>{% endblock %}
