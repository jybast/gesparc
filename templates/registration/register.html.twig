{% extends 'base.html.twig' %}

{% block title %}Register
{% endblock %}

{% block nav %}
	{% include "includes/_head.html.twig" %}

{% endblock %}
{% block body %}
	<div class="col-sm-12 col-md col-lg">
		<div class="container">
			<div class="page-content--bge5">
				<div class="register-wrap">
					<div class="login-logo">
						<a href="#">
							<img width="120px" height="45px" src="{{asset('assets/img/logo_horizontal.png')}}" alt="Gesparc">
						</a>
					</div>
					{% for flashError in app.flashes('verify_email_error') %}
						<div class="alert alert-danger" role="alert">{{ flashError }}</div>
					{% endfor %}
					<div class="col-md-12 col-lg d-block">
						<h1 class="h3 mb-3 text-center font-weight-normal">S'enregistrer</h1>

						{{ form_start(registrationForm) }}
						{{ form_row(registrationForm.email) }}
						{{ form_row(registrationForm.plainPassword, {label: 'Mot de passe'}) }}
						{{ form_row(registrationForm.firstname) }}
						{{ form_row(registrationForm.lastname) }}
						{{ form_row(registrationForm.address) }}
						{{ form_row(registrationForm.city) }}
						{{ form_row(registrationForm.postcode) }}
						{{ form_row(registrationForm.phone) }}
						{{ form_row(registrationForm.agreeTerms) }}

						<button type="submit" class="au-btn au-btn--block au-btn--green m-b-20">S'enregistrer</button>
						{{ form_end(registrationForm) }}

						<div>
							<a href="{{ path('app_logout')}}">
								Quitter
							</a>

						</div>

					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
